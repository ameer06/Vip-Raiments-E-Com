NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only secrets. Never prefix these with NEXT_PUBLIC_ and never import them
# from client components.
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key

# Razorpay Payment Integration (get from razorpay.com dashboard)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# UPI Gateway-less Payment Integration
# Your UPI ID for receiving payments (e.g. merchant@paytm, merchant@upi)
# Make this NEXT_PUBLIC_ so the frontend can detect if UPI is configured
NEXT_PUBLIC_MERCHANT_UPI_ID=your-upi-id@upi
